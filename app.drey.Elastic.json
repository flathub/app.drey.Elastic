{
    "app-id": "app.drey.Elastic",
    "runtime": "org.gnome.Platform",
    "runtime-version": "50",
    "sdk": "org.gnome.Sdk",
    "command": "app.drey.Elastic",
    "finish-args": [
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--device=dri"
    ],
    "cleanup": [
        "/include",
        "/lib/girepository-1.0",
        "/lib/pkgconfig",
        "/share/gir-1.0",
        "/share/vala"
    ],
    "modules": [
        {
            "name": "template-glib",
            "buildsystem": "meson",
            "config-opts": [
                "-Dintrospection=enabled",
                "-Dvapi=true"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://download.gnome.org/sources/template-glib/3.40/template-glib-3.40.0.tar.xz",
                    "sha256": "e533ec2f6c24cc6df66ac55ac824fadd1b4a5f433a11cbf3a6b25815c0cfcfd5",
                    "x-checker-data": {
                        "type": "gnome",
                        "name": "template-glib",
                        "stable-only": true
                    }
                }
            ]
        },
        {
            "name": "elastic",
            "buildsystem": "meson",
            "sources": [
                {
                    "type": "git",
                    "url": "https://gitlab.gnome.org/World/elastic.git",
                    "tag": "1.0.2",
                    "commit": "0f7ed57ed4d6ef5b28b5e9815f34eab2ad71ef3b",
                    "x-checker-data": {
                        "type": "git",
                        "name": "^([\\d.])$"
                    }
                }
            ]
        }
    ]
}
